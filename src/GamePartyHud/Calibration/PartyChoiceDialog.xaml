<ui:FluentWindow x:Class="GamePartyHud.Calibration.PartyChoiceDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Game Party HUD — Party"
                 Width="480" Height="430"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Game Party HUD — Party"/>

        <StackPanel Grid.Row="1" Margin="24,0,24,24">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ready to play!" Margin="0,0,0,2"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,20">
                Create a new party to play with friends, or join an existing one using a code they've shared.
            </TextBlock>

            <ui:Button Content="Create new party"
                       Icon="AddCircle24"
                       Appearance="Primary"
                       HorizontalAlignment="Stretch"
                       HorizontalContentAlignment="Left"
                       Padding="16,12"
                       Click="OnCreate"/>
            <TextBlock Text="Generates a 6-character code you can share with your teammates."
                       Opacity="0.7" FontSize="11" Margin="4,4,0,14"
                       TextWrapping="Wrap"/>

            <ui:Button Content="Join existing party"
                       Icon="PlugConnected24"
                       HorizontalAlignment="Stretch"
                       HorizontalContentAlignment="Left"
                       Padding="16,12"
                       Click="OnJoin"/>
            <TextBlock Text="Enter a code you received from somebody else."
                       Opacity="0.7" FontSize="11" Margin="4,4,0,14"
                       TextWrapping="Wrap"/>

            <ui:Button Content="Skip — keep HUD running in tray"
                       Appearance="Secondary"
                       HorizontalAlignment="Stretch"
                       HorizontalContentAlignment="Left"
                       Padding="16,12"
                       Click="OnSkip"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
