<ui:FluentWindow x:Class="GamePartyHud.Calibration.PartyCreatedDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Game Party HUD — Party Created"
                 Width="480" Height="340"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Game Party HUD — Party Created"/>

        <StackPanel Grid.Row="1" Margin="24,0,24,0">
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Party created" Margin="0,0,0,2"/>
            <TextBlock Opacity="0.85" TextWrapping="Wrap" Margin="0,0,0,16">
                Share this ID with your teammates. They can join by picking "Join existing party" and entering this code.
            </TextBlock>

            <Border Background="#22FFFFFF" CornerRadius="6" Padding="16,14"
                    BorderBrush="#33FFFFFF" BorderThickness="1">
                <TextBlock x:Name="IdText"
                           FontSize="36" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           FontFamily="Consolas, Cascadia Mono, monospace"
                           Text="XXXXXX"/>
            </Border>

            <TextBlock x:Name="StatusText"
                       Opacity="0.7" FontSize="11"
                       Margin="0,14,0,0"
                       TextWrapping="Wrap"
                       Text="Waiting for teammates to join…"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="24,8,24,16">
            <ui:Button Content="Copy ID" Icon="Copy24"
                       Appearance="Secondary" Margin="0,0,8,0"
                       Click="OnCopy"/>
            <ui:Button Content="Done (minimize)" Icon="Checkmark24"
                       Appearance="Primary" IsDefault="True"
                       Click="OnDone"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
