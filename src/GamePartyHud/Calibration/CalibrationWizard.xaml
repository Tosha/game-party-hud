<Window x:Class="GamePartyHud.Calibration.CalibrationWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibrate character"
        Width="480" Height="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="Steps" Grid.Row="0">
            <TabItem Header="1. Character">
                <StackPanel Margin="8">
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                        Make sure your character's HP is full. Click the button below
                        and drag a box around your character name <Italic>and</Italic> your HP bar together
                        — from just above the name to just below the HP bar.
                        The app figures out which part is the name and which is the bar.
                    </TextBlock>
                    <Button x:Name="PickRegionButton" Content="Pick character region" Padding="10,6"
                            HorizontalAlignment="Left" Click="OnPickRegion"/>
                    <TextBlock x:Name="RegionStatus" Margin="0,12,0,0" Foreground="DarkGreen" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="2. Role">
                <StackPanel Margin="8">
                    <TextBlock Text="Pick your role:" Margin="0,0,0,8"/>
                    <ComboBox x:Name="RoleCombo" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="3. Confirm">
                <StackPanel Margin="8">
                    <TextBlock Text="Your nickname (edit if OCR got it wrong, or type it in if OCR didn't pick it up):"
                               TextWrapping="Wrap" Margin="0,0,0,4"/>
                    <TextBox x:Name="NickText" Width="260" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BackBtn" Content="Back" Padding="12,6" Margin="0,0,8,0" Click="OnBack"/>
            <Button x:Name="NextBtn" Content="Next" Padding="12,6" Click="OnNext"/>
        </StackPanel>
    </Grid>
</Window>
