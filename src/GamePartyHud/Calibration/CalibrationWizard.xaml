<ui:FluentWindow x:Class="GamePartyHud.Calibration.CalibrationWizard"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Calibrate character"
                 Width="520" Height="400"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Calibrate character"/>

        <Grid Grid.Row="1" Margin="16,0,16,0">
            <TabControl x:Name="Steps">
                <TabItem Header="1. Character">
                    <StackPanel Margin="8">
                        <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                            Make sure your character's HP is full. Click the button below
                            and drag a box around your character name <Italic>and</Italic> your HP bar together —
                            from just above the name to just below the HP bar.
                            The app figures out which part is the name and which is the bar.
                        </TextBlock>
                        <ui:Button x:Name="PickRegionButton"
                                   Appearance="Primary"
                                   Icon="Target24"
                                   Content="Pick character region"
                                   HorizontalAlignment="Left"
                                   Click="OnPickRegion"/>
                        <TextBlock x:Name="RegionStatus" Margin="0,12,0,0"
                                   Foreground="{DynamicResource SystemAccentColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="2. Role">
                    <StackPanel Margin="8">
                        <TextBlock Text="Pick your role:" Margin="0,0,0,8"/>
                        <ComboBox x:Name="RoleCombo" Width="220" HorizontalAlignment="Left"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="3. Confirm">
                    <StackPanel Margin="8">
                        <TextBlock Text="Your nickname (edit if OCR got it wrong, or type it in if OCR didn't pick it up):"
                                   TextWrapping="Wrap" Margin="0,0,0,6"/>
                        <ui:TextBox x:Name="NickText" Width="300" HorizontalAlignment="Left"
                                    PlaceholderText="Enter your character name"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,8,16,16">
            <ui:Button x:Name="BackBtn" Content="Back" Icon="ArrowLeft24"
                       Appearance="Secondary" Margin="0,0,8,0" Click="OnBack"/>
            <ui:Button x:Name="NextBtn" Content="Next" Icon="ArrowRight24"
                       Appearance="Primary" Click="OnNext"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
