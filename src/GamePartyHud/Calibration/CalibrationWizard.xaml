<Window x:Class="GamePartyHud.Calibration.CalibrationWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calibrate character"
        Width="480" Height="340"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl x:Name="Steps" Grid.Row="0">
            <TabItem Header="1. HP bar">
                <StackPanel Margin="8">
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                        Make sure your character's HP is full, then click the button below
                        and drag a box around your HP bar.
                    </TextBlock>
                    <Button x:Name="PickHpButton" Content="Pick HP bar region" Padding="10,6"
                            HorizontalAlignment="Left" Click="OnPickHp"/>
                    <TextBlock x:Name="HpStatus" Margin="0,12,0,0" Foreground="DarkGreen" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="2. Nickname">
                <StackPanel Margin="8">
                    <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                        Drag a box around your character's name as it appears on screen.
                    </TextBlock>
                    <Button x:Name="PickNickButton" Content="Pick nickname region" Padding="10,6"
                            HorizontalAlignment="Left" Click="OnPickNick"/>
                    <TextBlock x:Name="NickStatus" Margin="0,12,0,0" Foreground="DarkGreen" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="3. Role">
                <StackPanel Margin="8">
                    <TextBlock Text="Pick your role:" Margin="0,0,0,8"/>
                    <ComboBox x:Name="RoleCombo" Width="200" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="4. Confirm">
                <StackPanel Margin="8">
                    <TextBlock Text="Your nickname (edit if OCR got it wrong):" Margin="0,0,0,4"/>
                    <TextBox x:Name="NickText" Width="260" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BackBtn" Content="Back" Padding="12,6" Margin="0,0,8,0" Click="OnBack"/>
            <Button x:Name="NextBtn" Content="Next" Padding="12,6" Click="OnNext"/>
        </StackPanel>
    </Grid>
</Window>
