<ui:FluentWindow x:Class="GamePartyHud.Calibration.CalibrationWizard"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="Game Party HUD — Setup"
                 Width="560" Height="520"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Game Party HUD — Setup"/>

        <StackPanel Grid.Row="1" Margin="24,0,24,0">
            <!-- HP bar section -->
            <TextBlock FontSize="14" FontWeight="SemiBold" Text="HP bar region"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.8" Margin="0,2,0,8">
                Make sure your HP is full in-game. Click below and drag a tight box around your HP bar only — no nickname, no other bars, no frame.
            </TextBlock>
            <StackPanel Orientation="Horizontal">
                <ui:Button x:Name="PickRegionButton"
                           Appearance="Primary"
                           Icon="Target24"
                           Content="Pick HP bar region"
                           Click="OnPickRegion"/>
                <TextBlock x:Name="RegionStatus" Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="340"
                           Foreground="{DynamicResource SystemAccentColorSecondaryBrush}"/>
            </StackPanel>

            <!-- Nickname section -->
            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Nickname" Margin="0,22,0,0"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.8" Margin="0,2,0,6">
                What your teammates will see on the HUD.
            </TextBlock>
            <ui:TextBox x:Name="NickText" MaxLength="32"
                        PlaceholderText="Your character name" HorizontalAlignment="Stretch"/>

            <!-- Role section -->
            <TextBlock FontSize="14" FontWeight="SemiBold" Text="Role" Margin="0,22,0,0"/>
            <TextBlock TextWrapping="Wrap" Opacity="0.8" Margin="0,2,0,6">
                Shown as a small icon next to your name.
            </TextBlock>
            <ComboBox x:Name="RoleCombo" Width="240" HorizontalAlignment="Left"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="24,8,24,16">
            <ui:Button Content="Cancel"
                       Appearance="Secondary" Margin="0,0,8,0"
                       IsCancel="True" Click="OnCancel"/>
            <ui:Button Content="Continue"
                       Icon="ArrowRight24"
                       Appearance="Primary" IsDefault="True"
                       Click="OnSave"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
