<ui:FluentWindow x:Class="GamePartyHud.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:local="clr-namespace:GamePartyHud"
                 xmlns:bars="clr-namespace:GamePartyHud.Bars"
                 Title="Game Party HUD"
                 Icon="pack://application:,,,/app.ico"
                 SizeToContent="WidthAndHeight"
                 MinWidth="700"
                 WindowStartupLocation="CenterScreen"
                 WindowBackdropType="Mica"
                 ExtendsContentIntoTitleBar="True"
                 ResizeMode="CanMinimize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Title bar -->
            <RowDefinition Height="Auto"/>   <!-- Fullscreen disclaimer -->
            <RowDefinition Height="Auto"/>   <!-- Two-column content (Auto, not *, so the window auto-sizes flush with the footer) -->
            <RowDefinition Height="Auto"/>   <!-- Footer -->
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Game Party HUD"/>

        <!-- Fullscreen disclaimer: one-time persistent notice (existing
             behavior — IsOpen seeded from AppConfig.FullscreenDisclaimerDismissed,
             user dismissal persisted via OnFullscreenDisclaimerIsOpenChanged). -->
        <ui:InfoBar Grid.Row="1"
                    x:Name="FullscreenDisclaimer"
                    Severity="Warning"
                    IsClosable="True"
                    Margin="24,8,24,12"
                    Title="If your game runs in fullscreen, the HUD may not be visible."
                    Message="Workaround: use borderless / windowed-fullscreen mode, or drag the HUD onto a second monitor."/>

        <!-- Two-column content area. Left column flexes; right column is
             a fixed 320px so the Party UI stays compact instead of
             stretching out across half the window. -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>  <!-- Left content (Auto, not *, so the window auto-sizes flush with the right edge) -->
                <ColumnDefinition Width="Auto"/>  <!-- Divider -->
                <ColumnDefinition Width="300"/>   <!-- Right (fixed Party panel, tightened from 320) -->
            </Grid.ColumnDefinitions>

            <!-- LEFT COLUMN: Profile + Bars.
                 Grid.IsSharedSizeScope so the Profile-header grid and the
                 Nickname/Role grid below it share column widths via
                 SharedSizeGroup — keeps PresetCombo's right edge flush with
                 RoleCombo's right edge regardless of where the StackPanel
                 stretches to. -->
            <StackPanel Grid.Column="0" Margin="24,4,12,12" Grid.IsSharedSizeScope="True">
                <!-- Profile sub-section. Heading shares a row with the preset
                     selector; switching a preset swaps Nickname/Role/Bars
                     content via PopulateFromConfig. -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ProfileLeftCol"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ProfileRightCol"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Profile" FontSize="18" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <!-- Styled deliberately understated (transparent bg, no
                         border, tight padding) so the selector reads as a
                         secondary affordance, not a primary input. The
                         dropdown items themselves still get the wpfui combo
                         look. -->
                    <ComboBox Grid.Column="1"
                              x:Name="PresetCombo"
                              Width="160"
                              MinHeight="0"
                              Padding="6,1"
                              BorderThickness="0"
                              Background="Transparent"
                              FontSize="13"
                              VerticalAlignment="Center"
                              ToolTip="Active character preset. Switch to load a different character's nickname, role, and bar regions. Click ✏ on a row to rename, ✕ to delete, or '+ New preset' to add another."
                              SelectionChanged="OnPresetChanged">
                        <!-- Override the wpfui ComboBoxItem default MinHeight
                             (which produces ~50px-tall rows) so the dropdown
                             stays compact. Padding 8,2 + MinHeight 0 yields
                             ~24px rows, matching the Role combo's visual scale. -->
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="8,2"/>
                                <Setter Property="MinHeight" Value="0"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBox.Resources>
                            <!-- Regular preset row template:
                                 [Name (display or inline-edit) | ✏ rename | ✕ delete] -->
                            <DataTemplate x:Key="PresetRowTemplate">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>  <!-- pencil -->
                                        <ColumnDefinition Width="Auto"/>  <!-- × -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Display name (default) — collapsed when IsEditing -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Inline-edit TextBox — visible only when IsEditing -->
                                    <TextBox Grid.Column="0"
                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             FontSize="13"
                                             VerticalAlignment="Center"
                                             Tag="{Binding Id}"
                                             KeyDown="OnPresetRenameKeyDown"
                                             LostKeyboardFocus="OnPresetRenameLostFocus">
                                        <TextBox.Style>
                                            <Style TargetType="TextBox">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBox.Style>
                                    </TextBox>

                                    <!-- Pencil icon: starts inline rename -->
                                    <Button Grid.Column="1"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="4,0" Margin="4,0,0,0"
                                            Tag="{Binding Id}"
                                            Click="OnPresetRenameClick"
                                            ToolTip="Rename">
                                        <TextBlock Text="✏" FontSize="12"/>
                                    </Button>

                                    <!-- × icon: delete with confirmation. Refuses
                                         to delete the last remaining preset. -->
                                    <Button Grid.Column="2"
                                            Background="Transparent" BorderThickness="0"
                                            Padding="4,0" Margin="2,0,0,0"
                                            Tag="{Binding Id}"
                                            Click="OnPresetDeleteClick"
                                            ToolTip="Delete">
                                        <TextBlock Text="✕" FontSize="12"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                            <!-- "+ New preset" command-row template, styled
                                 distinctly so it reads as an action, not a
                                 preset name. -->
                            <DataTemplate x:Key="CommandRowTemplate">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="+" FontWeight="Bold" Margin="0,0,6,0"
                                               FontSize="13" VerticalAlignment="Center"
                                               Foreground="#FF66B2FF"/>
                                    <TextBlock Text="New preset" FontSize="13"
                                               VerticalAlignment="Center"
                                               Foreground="#FF66B2FF"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.Resources>
                        <ComboBox.ItemTemplateSelector>
                            <local:PresetItemTemplateSelector
                                PresetRowTemplate="{StaticResource PresetRowTemplate}"
                                CommandRowTemplate="{StaticResource CommandRowTemplate}"/>
                        </ComboBox.ItemTemplateSelector>
                    </ComboBox>
                </Grid>

                <!-- Nickname (left, flex) + Role (right, fixed) on one row.
                     2-row grid: labels on top, inputs below. Helper text
                     lives in the Nickname label's tooltip. -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ProfileLeftCol"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ProfileRightCol"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Nickname" FontWeight="SemiBold" Margin="0,0,0,2"
                               ToolTip="What your teammates see on the HUD."/>
                    <ui:TextBox Grid.Row="1" Grid.Column="0"
                                x:Name="NickText" MaxLength="32"
                                Width="220" Margin="0,0,16,0"
                                PlaceholderText="Your character name"
                                TextChanged="OnNicknameChanged"/>

                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Role" FontWeight="SemiBold" Margin="0,0,0,2"/>
                    <ComboBox Grid.Row="1" Grid.Column="1"
                              x:Name="RoleCombo" Width="160"
                              SelectionChanged="OnRoleChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Glyph}" FontSize="13"
                                               Width="18" TextAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Label}" Margin="6,0,0,0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <!-- Bars sub-section. Three uniform cards; each card carries
                     its own live preview + validation. Toggle on Stamina/Mana
                     preserves calibration when disabled (toggle off => bar
                     not broadcast, but the calibration is retained). -->
                <Separator Margin="0,10,0,0" Opacity="0.3"/>
                <TextBlock Text="Bars" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,10"
                           ToolTip="Track HP — plus optional stamina and mana — by dragging a tight box around each bar in your game."/>

                <!-- HorizontalAlignment=Left + fixed Width pins the Bars cards
                     to the same width as the Profile grid above (Nickname
                     TextBox 220 + 16 margin + Role combo 160 = ~396px,
                     rounded up). Without this, cards stretch to whatever
                     the left column happens to be, which (a) makes the
                     section visually unbalanced vs Profile and (b) lets
                     small per-card width drift sneak in for the bar
                     previews. Fixed Width => all three previews are
                     guaranteed identical width. -->
                <StackPanel HorizontalAlignment="Left" Width="396">
                    <bars:BarCard x:Name="HpCard"
                                  BarName="HP"
                                  IsToggleable="False"
                                  IsBarEnabled="True"
                                  Margin="0,0,0,8"
                                  PickRequested="OnHpPickRequested"/>
                    <bars:BarCard x:Name="StaminaCard"
                                  BarName="Stamina"
                                  IsToggleable="True"
                                  Margin="0,0,0,8"
                                  PickRequested="OnStaminaPickRequested"
                                  EnabledChanged="OnStaminaEnabledChanged"/>
                    <bars:BarCard x:Name="ManaCard"
                                  BarName="Mana"
                                  IsToggleable="True"
                                  PickRequested="OnManaPickRequested"
                                  EnabledChanged="OnManaEnabledChanged"/>
                </StackPanel>
            </StackPanel>

            <!-- Vertical divider between columns -->
            <Border Grid.Column="1"
                    Width="1"
                    Background="#22FFFFFF"
                    Margin="0,8"/>

            <!-- RIGHT COLUMN: Party + Status InfoBar. Rows are Auto so the
                 column sizes to its content; PartyStatus sits just below
                 the Party UI when shown (no longer pinned to the
                 column bottom, since the column no longer has slack
                 height under SizeToContent). -->
            <Grid Grid.Column="2" Margin="12,12,12,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" VerticalAlignment="Top">
                    <!-- Party heading shares a row with the Settings gear.
                         Putting the gear here (instead of in a dedicated
                         header row above the content) frees ~30px of
                         vertical chrome at the top of the window. -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Party"
                                   FontSize="18" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <ui:Button Grid.Column="1" x:Name="SettingsButton"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   Padding="6,3"
                                   ToolTip="Settings"
                                   Click="OnOpenSettings">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="18"/>
                        </ui:Button>
                    </Grid>

                    <!-- Not in a party yet -->
                    <StackPanel x:Name="NotInPartySection">
                        <TextBlock Text="You're not in a party yet."
                                   Margin="0,0,0,14" Opacity="0.85"/>

                        <StackPanel Orientation="Horizontal">
                            <ui:Button x:Name="CreateButton"
                                       Content="Create new party"
                                       Icon="AddCircle24"
                                       Appearance="Primary"
                                       Padding="16,8"
                                       Click="OnCreate"/>
                            <ui:ProgressRing x:Name="CreateProgress"
                                             Width="20" Height="20"
                                             IsIndeterminate="True"
                                             Visibility="Collapsed"
                                             Margin="12,0,0,0"
                                             VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Opacity="0.6" FontSize="11" Margin="2,6,0,0" TextWrapping="Wrap"
                                   Text="Generates a 6-character code you share with your teammates."/>

                        <TextBlock Text="or join an existing party" Opacity="0.75" Margin="0,20,0,6"/>
                        <!-- Grid (not StackPanel) for the join row so the Join
                             button can stretch to fill the remaining width.
                             Its right edge ends up flush with the gear button
                             at top-right and the Quit button at bottom-right. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>  <!-- TextBox -->
                                <ColumnDefinition Width="*"/>     <!-- Join (stretches) -->
                                <ColumnDefinition Width="Auto"/>  <!-- ProgressRing -->
                            </Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        x:Name="PartyIdInput"
                                        MaxLength="6"
                                        CharacterCasing="Upper"
                                        PlaceholderText="ABCDEF"
                                        Width="180"
                                        FontSize="14"
                                        TextChanged="OnPartyIdInputChanged"
                                        KeyDown="OnPartyIdInputKeyDown"/>
                            <ui:Button Grid.Column="1"
                                       x:Name="JoinButton"
                                       Content="Join"
                                       Icon="PlugConnected24"
                                       Appearance="Secondary"
                                       IsEnabled="False"
                                       Margin="8,0,0,0"
                                       Padding="16,0"
                                       HorizontalAlignment="Stretch"
                                       VerticalAlignment="Stretch"
                                       Click="OnJoin"/>
                            <ui:ProgressRing Grid.Column="2"
                                             x:Name="JoinProgress"
                                             Width="20" Height="20"
                                             IsIndeterminate="True"
                                             Visibility="Collapsed"
                                             Margin="12,0,0,0"
                                             VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>

                    <!-- In a party -->
                    <StackPanel x:Name="InPartySection" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="You're in party:"
                                       VerticalAlignment="Center" Opacity="0.85"/>
                            <!-- Click anywhere on this badge to copy the party ID. -->
                            <Border CornerRadius="4"
                                    Padding="10,4" Margin="10,0,0,0"
                                    BorderBrush="#33FFFFFF" BorderThickness="1"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="OnPartyIdClick"
                                    ToolTip="Click to copy">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#22FFFFFF"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#33FFFFFF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock x:Name="PartyIdDisplay"
                                           FontFamily="Consolas, Cascadia Mono, monospace"
                                           FontSize="18" FontWeight="Bold"
                                           Text="XXXXXX"/>
                            </Border>
                            <TextBlock x:Name="CopyFeedback"
                                       Text="✓ Copied"
                                       VerticalAlignment="Center"
                                       Margin="12,0,0,0"
                                       FontWeight="SemiBold"
                                       Foreground="#FFAEE6AE"
                                       Opacity="0"
                                       IsHitTestVisible="False"/>
                        </StackPanel>
                        <TextBlock x:Name="MemberCountDisplay"
                                   Margin="0,10,0,14" Opacity="0.85"
                                   Text="1 member (you)"/>

                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="Leave party"
                                       Icon="SignOut24"
                                       Appearance="Danger"
                                       Padding="14,6"
                                       Click="OnLeave"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Party status InfoBar pinned to bottom of right column -->
                <ui:InfoBar Grid.Row="1"
                            x:Name="PartyStatus"
                            VerticalAlignment="Bottom"
                            Margin="0,12,0,0"
                            IsOpen="False"
                            IsClosable="True"/>
            </Grid>
        </Grid>

        <!-- Footer: Close to tray + Quit app. Margins trimmed (right 24→12
             to line up with the right column's inner content edge;
             bottom 16→8 to drop the empty band below the buttons). -->
        <Grid Grid.Row="3" Margin="24,8,12,8">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="Close to tray"
                           Appearance="Secondary"
                           Icon="ChevronDown24"
                           Padding="14,6"
                           Click="OnCloseToTray"/>
                <ui:Button Content="Quit app"
                           Icon="Power24"
                           Appearance="Danger"
                           Margin="8,0,0,0"
                           Padding="14,6"
                           Click="OnQuitApp"/>
            </StackPanel>
        </Grid>
    </Grid>
</ui:FluentWindow>
